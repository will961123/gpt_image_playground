{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gpt-img",
  "main": "src/worker.ts",
  "compatibility_date": "2026-04-28",
  "observability": {
    "enabled": true
  },
  "assets": {
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api-proxy/*"]
  },
  "vars": {
    "UPSTREAM_API_BASE_URL": "https://anyrouter.top"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
